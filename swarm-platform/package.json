{
  "name": "openclaw-swarm-platform",
  "version": "0.1.0",
  "description": "OpenClaw swarm orchestrator, scoring engine, and live leaderboard dashboard",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file=.env src/server.js",
    "dev": "node --env-file=.env --watch src/server.js",
    "lint": "echo 'No linter configured yet'",
    "check": "node src/server.js --check",
    "test": "node --test --test-concurrency=1 tests/unit/*.test.js tests/integration/*.test.js tests/e2e/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  }
}
